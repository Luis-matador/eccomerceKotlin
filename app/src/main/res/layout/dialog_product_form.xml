<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        <ImageView
            android:id="@+id/ivProductPreview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_card"
            android:contentDescription="@string/product_image_desc"
            android:padding="16dp"
            android:src="@drawable/ic_product_placeholder" />
        <Button
            android:id="@+id/btnPickProductImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/pick_product_image" />
        <EditText
            android:id="@+id/etProductTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/product_title_hint"
            android:inputType="textCapSentences" />
        <EditText
            android:id="@+id/etProductPlatform"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/product_platform_hint" />
        <EditText
            android:id="@+id/etProductCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/product_category_hint" />
        <EditText
            android:id="@+id/etProductPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/product_price_hint"
            android:inputType="numberDecimal" />
        <EditText
            android:id="@+id/etProductStock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/product_stock_hint"
            android:inputType="number" />
        <EditText
            android:id="@+id/etProductDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="top"
            android:hint="@string/product_description_hint"
            android:inputType="textMultiLine"
            android:minLines="4" />
        <Switch
            android:id="@+id/switchFeatured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/featured_switch" />
    </LinearLayout>
</ScrollView>
